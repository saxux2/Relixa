# ===========================================
# FIREBASE CONFIGURATION
# ===========================================
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# ===========================================
# STELLAR BLOCKCHAIN CONFIGURATION
# ===========================================

# Stellar Network (testnet or public)
VITE_STELLAR_NETWORK=testnet

# Stellar Horizon API URL (Testnet)
VITE_STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Stellar RPC URL for Soroban smart contracts (Testnet)
VITE_STELLAR_RPC_URL=https://soroban-testnet.stellar.org:443

# Stellar Network Passphrase
VITE_STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# USDC Contract Address on Stellar Testnet
VITE_STELLAR_USDC_ADDRESS=CAQYAU4RVHTPV7KXQNHK73MQKXSV4DKP2NOFQXHDBT3IUCDPBDUU6Y3

# Campaign Factory Contract (deploy and add address)
VITE_STELLAR_CAMPAIGN_CONTRACT=YOUR_CAMPAIGN_CONTRACT_ADDRESS

# Beneficiary Wallet Contract (deploy and add address)
VITE_STELLAR_BENEFICIARY_CONTRACT=YOUR_BENEFICIARY_CONTRACT_ADDRESS

# Super Admin Stellar Public Key (Stellar addresses start with G)
VITE_SUPER_ADMIN_ADDRESS=GXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ===========================================
# WEILCHAIN AUDIT TRAIL CONFIGURATION
# ===========================================

# WeilChain Sentinel URL (for audit logging)
VITE_WEILCHAIN_SENTINEL_URL=https://sentinel.unweil.me

# Audit Trail Contract Address on WeilChain
VITE_WEILCHAIN_AUDIT_CONTRACT=aaaaaasmrquobjshwok2uyfz7gcgg6dbuhvusublvgyrimskqkwws5udqu

# WeilChain Signer Private Key (for audit logging)
VITE_WEILCHAIN_SIGNER_KEY=your_weilchain_signer_private_key_here

# ===========================================
# APP CONFIGURATION
# ===========================================
VITE_APP_NAME=Relifo
VITE_APP_ENV=development
